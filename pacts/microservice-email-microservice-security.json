{
  "consumer": {
    "name": "microservice-email"
  },
  "messages": [
    {
      "contents": {
        "id": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
        "link": "http://localhost:8080/reset-password?token=x",
        "to": "user@example.com",
        "type": "PASSWORD_RESET"
      },
      "description": "a password reset mail request",
      "generators": {
        "body": {
          "$.id": {
            "type": "Uuid"
          }
        }
      },
      "matchingRules": {
        "body": {
          "$.id": {
            "combine": "AND",
            "matchers": [
              {
                "match": "regex",
                "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              }
            ]
          },
          "$.link": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.to": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        }
      },
      "metaData": {
        "contentType": "application/json"
      }
    },
